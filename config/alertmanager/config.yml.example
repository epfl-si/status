global:
  smtp_smarthost: ''
  smtp_auth_username: ''
  smtp_auth_password: ''
  smtp_require_tls: true
  smtp_from: '' # smtp_from have the same value as smtp_auth_username
  send_resolved: true
route:
  # When a new group of alerts is created by an incoming alert, wait at
  # least 'group_wait' to send the initial notification.
  # This way ensures that you get multiple alerts for the same group that start
  # firing shortly after another are batched together on the first
  # notification.
  group_wait: 45s
  # When the first notification was sent, wait 'group_interval' to send a batch
  # of new alerts that started firing for that group.
  # group_interval: 10m
  # If an alert has successfully been sent, wait 'repeat_interval' to
  # resend them.
  repeat_interval: 5m
  # A default receiver
  receiver: status-admins
  routes:
    - receiver: null
      matchers:
        - severity=none
    - receiver: status-unexist-epfl-ch-httpdown
      group_by:
        - instance
      matchers:
        - instance="https://unexist.epfl.ch"
        - service="httpdown"
    - receiver: status-eeee-epfl-ch-httpdown
      group_by:
        - instance
      matchers:
        - instance="https://eeee.epfl.ch"
        - service="httpdown"

receivers:
  - name: status-admins
    email_configs:
      - to: status-admins@epfl.ch
        headers:
          Subject: /!\ Alert - {{ .GroupLabels.instance }} have problems, please look ASAP
        text: "{{ .CommonAnnotations.summary }}"
  - name: status-unexist-epfl-ch-httpdown
    email_configs:
      - to: ""
        headers:
          Subject: /!\ Alert - {{ .GroupLabels.instance }} is down, please look ASAP
        text: "{{ .CommonAnnotations.summary }}"
  - name: status-eeee-epfl-ch-httpdown
    email_configs:
      - to: ""
        headers:
          Subject: /!\ Alert - {{ .GroupLabels.instance }} is down, please look ASAP
        text: "{{ .CommonAnnotations.summary }}"

